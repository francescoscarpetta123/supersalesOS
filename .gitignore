# Dependencies — must never be committed (Railway runs npm ci; tracked trees cause EBUSY on .vite, etc.)
node_modules/
client/node_modules/
server/node_modules/
**/node_modules/

# Vite cache (configured under client/.vite and the old default client/node_modules/.vite)
**/.vite/
client/.vite/
client/node_modules/.vite/

dist/
.env
.data/
*.log
.DS_Store
