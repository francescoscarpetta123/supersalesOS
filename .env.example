GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ANTHROPIC_API_KEY=
PORT=3001

# Required in production — random string (e.g. openssl rand -hex 32). Changing it logs everyone out.
# Sessions are stored under .data/sessions/ (gitignored).
SESSION_SECRET=

# Must exactly match the “Authorized redirect URI” in Google Cloud:
#   ${PUBLIC_URL}/auth/google/callback
# Single-URL app (npm start):  http://localhost:3001
# Vite dev (npm run dev):       http://localhost:5173  (proxy forwards /auth to API)
PUBLIC_URL=http://localhost:3001

# Listen on all interfaces for LAN access (default 0.0.0.0)
# HOST=0.0.0.0

# Optional: exact URL to open in the browser after Google OAuth (no trailing slash).
# Default: same as the request (or X-Forwarded-Host from Vite/nginx). Use if redirects go to the wrong place.
# POST_OAUTH_REDIRECT=http://localhost:5173

# HTTPS cookies: set COOKIE_SECURE=1, or rely on NODE_ENV=production (Railway sets this on deploy).
# COOKIE_SECURE=1

# Optional: separate API origin for static builds (usually leave unset when API serves client/dist)
# VITE_API_ORIGIN=

# Railway (single service): enable public networking, set GOOGLE_* / ANTHROPIC_* / SESSION_SECRET in the dashboard.
# OAuth redirect in Google Cloud: https://<your-service-domain>/auth/google/callback
# If PUBLIC_URL is unset, the app uses https://${RAILWAY_PUBLIC_DOMAIN} when Railway provides it (custom domain: set PUBLIC_URL).

# Google Cloud OAuth redirect URI must match: ${PUBLIC_URL or Railway HTTPS URL}/auth/google/callback
# OAuth scopes include gmail.readonly + openid/email/profile (required for account identity).
